def _dedupe_proxy_pool(items):
    result = []
    for item in items:
        candidate = str(item or "").strip()
        if candidate and candidate not in result:
            result.append(candidate)
    return result


def _proxy_hostname(proxy_url):
    try:
        return (urlparse(str(proxy_url or "")).hostname or "").strip()
    except Exception:
        return ""


def _sort_dltv_proxy_pool(items):
    # Stable order by hostname for deterministic rotation; banned hosts go last.
    def _rank(proxy_url):
        host = _proxy_hostname(proxy_url)
        if host in DLTV_BANNED_PROXIES:
            return (100, host, str(proxy_url))
        return (0, host, str(proxy_url))

    return sorted(_dedupe_proxy_pool(items), key=_rank)




