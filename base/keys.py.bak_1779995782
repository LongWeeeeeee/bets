def _filter_banned_proxies(pool):
    """Remove DLTV-banned proxies from pool."""
    result = []
    for proxy in pool:
        host = _proxy_hostname(proxy)
        if host and host not in DLTV_BANNED_PROXIES:
            result.append(proxy)
        else:
            print(f"   🚫 DLTV banned proxy filtered: {proxy}")
    return result


